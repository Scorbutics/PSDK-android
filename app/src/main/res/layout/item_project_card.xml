<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="@dimen/corner_radius_md"
    app:strokeColor="@color/colorSurfaceVariant"
    app:strokeWidth="1dp"
    app:cardElevation="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/card_padding">

        <!-- Project icon placeholder -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_step_active"
            android:layout_marginEnd="@dimen/spacing_md" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/projectName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Psdk.Subtitle"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/projectStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Psdk.Caption" />
        </LinearLayout>

        <!-- Sync warning -->
        <ImageView
            android:id="@+id/syncWarningIcon"
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:src="@android:drawable/ic_dialog_alert"
            android:visibility="gone"
            app:tint="@color/colorWarning"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <!-- Delete button -->
        <ImageView
            android:id="@+id/deleteButton"
            android:layout_width="@dimen/icon_lg"
            android:layout_height="@dimen/icon_lg"
            android:src="@android:drawable/ic_menu_delete"
            android:padding="@dimen/spacing_sm"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/colorOnSurfaceVariant" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
