<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Project header -->
        <TextView
            android:id="@+id/projectName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Psdk.Headline"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <TextView
            android:id="@+id/projectVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Psdk.Caption"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Actions card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:strokeColor="@color/colorSurfaceVariant"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIONS"
                    android:textAppearance="@style/TextAppearance.Psdk.Label"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/testGameButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Test Game"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    style="@style/Widget.Psdk.Button.Success" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/compileButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Compile"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    style="@style/Widget.Psdk.Button.Outlined" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/exportButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Export APK"
                    android:visibility="gone"
                    style="@style/Widget.Psdk.Button.Outlined" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Logs card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:strokeColor="@color/colorSurfaceVariant"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIAGNOSTICS"
                    android:textAppearance="@style/TextAppearance.Psdk.Label"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/gameLogsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Game Logs"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    style="@style/Widget.Psdk.Button.Text" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/compilationLogsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Compilation Logs"
                    android:visibility="gone"
                    style="@style/Widget.Psdk.Button.Text" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
