<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="@dimen/corner_radius_md"
    app:strokeColor="@color/colorSurfaceVariant"
    app:strokeWidth="1dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <!-- Step header -->
        <LinearLayout
            android:id="@+id/stepHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Status indicator -->
            <ImageView
                android:id="@+id/stepStatusIcon"
                android:layout_width="@dimen/step_indicator_size"
                android:layout_height="@dimen/step_indicator_size"
                android:layout_marginEnd="@dimen/spacing_md" />

            <TextView
                android:id="@+id/stepTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Psdk.Title" />

            <ImageView
                android:id="@+id/expandIcon"
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@android:drawable/arrow_down_float"
                android:visibility="gone"
                app:tint="@color/colorOnSurfaceVariant" />
        </LinearLayout>

        <!-- Expandable log section -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/logContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp"
            android:layout_marginTop="@dimen/spacing_sm"
            android:visibility="gone"
            android:background="@color/colorBackground"
            android:padding="@dimen/spacing_sm">

            <TextView
                android:id="@+id/logText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Psdk.Monospace"
                android:textIsSelectable="true" />
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
