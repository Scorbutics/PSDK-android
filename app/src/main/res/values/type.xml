<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text Appearances -->
    <style name="TextAppearance.Psdk.Headline" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/colorOnBackground</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Psdk.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Psdk.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.Psdk.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.Psdk.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/colorOnSurfaceVariant</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TextAppearance.Psdk.Monospace" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="TextAppearance.Psdk.Label" parent="TextAppearance.MaterialComponents.Overline">
        <item name="android:textColor">@color/colorOnSurfaceVariant</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.08</item>
    </style>
</resources>
