<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Psdk" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/colorOnError</item>

        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowBackground">@color/colorBackground</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/colorOnBackground</item>
        <item name="android:textColorSecondary">@color/colorOnSurfaceVariant</item>

        <!-- Button styles -->
        <item name="materialButtonStyle">@style/Widget.Psdk.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.Psdk.Button.Outlined</item>
        <item name="floatingActionButtonStyle">@style/Widget.Psdk.FAB</item>

        <!-- Card style -->
        <item name="materialCardViewStyle">@style/Widget.Psdk.CardView</item>

        <!-- TextInput style -->
        <item name="textInputStyle">@style/Widget.Psdk.TextInputLayout</item>

        <!-- Bottom sheet -->
        <item name="bottomSheetDialogTheme">@style/Theme.Psdk.BottomSheet</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.Psdk.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">8dp</item>
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/colorOnPrimary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Psdk.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">8dp</item>
        <item name="strokeColor">@color/colorSurfaceVariant</item>
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Psdk.Button.Success" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">8dp</item>
        <item name="backgroundTint">@color/colorSecondary</item>
        <item name="android:textColor">@color/colorOnSecondary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Psdk.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- FAB -->
    <style name="Widget.Psdk.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="tint">@color/colorOnPrimary</item>
    </style>

    <!-- CardView -->
    <style name="Widget.Psdk.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/colorSurfaceVariant</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- TextInputLayout -->
    <style name="Widget.Psdk.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="boxBackgroundColor">@color/colorSurface</item>
        <item name="hintTextColor">@color/colorPrimary</item>
        <item name="android:textColorHint">@color/colorOnSurfaceVariant</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <!-- Bottom Sheet Theme -->
    <style name="Theme.Psdk.BottomSheet" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.Psdk.BottomSheet</item>
        <item name="android:colorBackground">@color/colorSurface</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="Widget.Psdk.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="backgroundTint">@color/colorSurface</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Psdk.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.Psdk.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
    </style>

    <!-- Dialog Theme -->
    <style name="Theme.Psdk.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.Psdk.Body</item>
    </style>
</resources>
